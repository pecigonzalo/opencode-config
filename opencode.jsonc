{
  "$schema": "https://opencode.ai/config.json",
  // Web
  "server": {
    "hostname": "127.0.0.1",
    "mdns": false,
  },
  "instructions": ["DEV_SPEC.md", "ONE_PAGER.md"],
  // Planner agent as default entry point (read-only planning, hands off to universal)
  "default_agent": "planner",
  // Agent model assignments
  "agent": {
    // Disable built-in agents (we have custom planner)
    "build": {
      "disable": true,
    },
    "plan": {
      "disable": true,
    },
    "explore": {
      "disable": true,
    },
    "general": {
      "disable": true,
    },
    // Primary agents (user-facing)
    "planner": {
      "model": "github-copilot/gpt-5.2", // Deep reasoning at standard cost for strategic planning
      "temperature": 0.4, // Slightly higher for creative problem decomposition
    },
    "orchestrator": {
      "model": "github-copilot/claude-sonnet-4.6", // Balanced for execution coordination
      "description": "Execution orchestrator that delegates to subagents, enforces quality gates, and drives tasks to completion. Can execute plans from planner or handle direct requests",
      "temperature": 0.3,
      "prompt": "{file:./agents/universal.md}",
      "permission": {
        "task": "allow",
        "read": "deny",
        "edit": "deny",
        "bash": "deny",
      },
    },
    "universal": {
      "model": "github-copilot/claude-sonnet-4.6", // Balanced for execution coordination
      "temperature": 0.3,
    },
    // Subagents (delegated to by primary agents)
    "explorer": {
      "model": "github-copilot/gpt-5-mini", // Free deep reasoning for fast discovery
      "temperature": 0.1,
    },
    "fast": {
      "model": "github-copilot/gpt-5.1-codex-mini", // Compact code reasoning at low cost
      "prompt": "{file:./agents/prompts/implementer.md}",
      "description": "Small-scope engineering agent for docs, tests, and bounded edits. Use for quick, low-risk changes with minimal coordination.",
      "mode": "subagent",
      "temperature": 0.2,
      "permission": {
        "task": "deny",
        "todoread": "deny",
        "todowrite": "deny",
      },
    },
    "balanced": {
      "model": "github-copilot/claude-sonnet-4.6",
      "prompt": "{file:./agents/prompts/implementer.md}",
      "description": "Implementation agent for standard multi-file features, refactors, and non-trivial bugfixes.",
      "mode": "subagent",
      "temperature": 0.3,
      "permission": {
        "task": "deny",
        "todoread": "deny",
        "todowrite": "deny",
      },
    },
    "deep": {
      "model": "github-copilot/claude-opus-4.6",
      "prompt": "{file:./agents/prompts/implementer.md}",
      "description": "Implementation agent for complex, multi-file work and debugging. Use when scope is uncertain, cross-cutting, or requires careful design and verification.",
      "mode": "subagent",
      "temperature": 0.3,
      "permission": {
        "task": "deny",
        "todoread": "deny",
        "todowrite": "deny",
      },
    },
    "deep-l": {
      "disable": true, // Disabled upstream
      "model": "github-copilot/gpt-5.2-codex", // 272k context, agentic tool use, deep reasoning
      "prompt": "{file:./agents/prompts/implementer.md}",
      "description": "Implementation agent with large context (272k) for broad-scope work spanning many files or requiring extended analysis.",
      "mode": "subagent",
      "temperature": 0.3,
      "permission": {
        "todoread": "deny",
        "todowrite": "deny",
        "task": "deny",
      },
    },
    "deep-xl": {
      "disable": true, // Out of tokens
      "model": "openai/gpt-5.3-codex", // Premium code-specialized model via OpenAI (400k context)
      "prompt": "{file:./agents/prompts/implementer.md}",
      "description": "Implementation agent with extra-large context (400k) for the broadest-scope work. Disabled by default — requires direct OpenAI API access.",
      "mode": "subagent",
      "temperature": 0.3,
      "permission": {
        "todoread": "deny",
        "todowrite": "deny",
        "task": "deny",
      },
    },
    "thinker": {
      "model": "github-copilot/gpt-5.2-codex", // 272k context, agentic tool use, deep reasoning
      "temperature": 0.5,
      "reasoningEffort": "high", // Leverage extended reasoning capabilities
    },
  },
  // Plugins for authentication
  "plugin": [],
  // Compaction
  "compaction": {
    "auto": true,
    "prune": true,
  },
  // Permissions
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "~/.config/opencode/**/*": "allow",
    },
    "list": "allow",
    "glob": "allow",
    "grep": "allow",
    "edit": "allow",
    "skill": "allow",
    "task": "deny",
    "lsp": "allow",
    "question": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "storeread": "allow",
    "storewrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "bash": {
      "*": "ask",
      "cat *": "allow",
      "cp *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "wc *": "allow",
      "git *": "allow",
      "git push *": "ask",
      "go build *": "allow",
      "go doc *": "allow",
      "go test *": "allow",
      "go mod *": "allow",
      "go docs *": "allow",
      "go list *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "uniq *": "allow",
      "ls *": "allow",
      "mv *": "ask",
      "rm *": "ask",
      "sort *": "allow",
      "sudo *": "ask",
      "tail *": "allow",
      "timeout *": "allow",
      "task *": "allow",
      "tee *": "allow",
    },
    "external_directory": {
      "*": "ask",
      "/tmp": "allow",
    },
    "doom_loop": "ask",
  },
  // MCP servers
  "mcp": {
    "btca": {
      "enabled": false,
      "type": "local",
      "command": ["bunx", "btca", "mcp"],
    },
    "GitHub Grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
    },
    "GitHub": {
      "enabled": false,
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "X-MCP-Readonly": "true",
      },
    },
    "Deep Wiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp",
    },
    "Vantage MCP": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.vantage.sh/mcp",
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:VANTAGE_API_TOKEN}",
      },
    },
  },
  // Misc settings
  "autoupdate": true,
  "share": "disabled",
}
